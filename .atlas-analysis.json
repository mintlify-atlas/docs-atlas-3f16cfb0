  "keyFeatures": [
    "Role-based access control (Owner, Supervisor, Operator, Admin)",
    "Client and quotation management with conversion to work orders",
    "Work order lifecycle tracking with status management",
    "Resource management for personnel and machinery",
    "Material inventory tracking with consumption logging",
    "Production workflow with event traceability",
    "Dashboard with KPIs and productivity reports",
    "Complete audit trail for all operations",
    "Docker-based on-premise deployment"
  ],
